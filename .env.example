# LLM Provider — set ONE of the following:
GITHUB_TOKEN=ghp_...           # GitHub Models (free tier, no OpenAI subscription needed)
OPENAI_API_KEY=sk-...          # OpenAI direct (takes precedence over GITHUB_TOKEN if both set)

ANTHROPIC_API_KEY=sk-ant-...   # Reserved for future Anthropic support
MAX_CONCURRENT_EXPERIMENTS=4
DATABASE_PATH=autoaw.db
DATASETS_DIR=datasets

